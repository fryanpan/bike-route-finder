# Copy to .env and fill in. All VITE_* vars are build-time — exposed in the
# bundle. Only put values here you're okay with a visitor seeing.
#
# Cloudflare Worker secrets (LINEAR_API_KEY, LINEAR_TEAM_ID, LINEAR_PROJECT_ID,
# LINEAR_ASSIGNEE_ID) are set via `wrangler secret put` and are NOT in .env.

# Sentry browser DSN for client-side error reporting. Optional — app runs
# without it. https://sentry.io/
VITE_SENTRY_DSN=

# Mapillary API token for street-level photo lookups in segment popups.
# Optional — popups show tags only if missing. https://www.mapillary.com/dashboard/developers
VITE_MAPILLARY_TOKEN=

# Calendly link shown as "Book a 15-min chat" in the feedback modal.
# Optional — the modal omits the link if this is unset.
VITE_CALENDLY_URL=
